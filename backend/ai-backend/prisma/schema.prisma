generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isActive          Boolean  @default(false)
  activationToken   String?
  resetToken        String?
  resetTokenExpiry  DateTime?
  workspaceUsers WorkspaceUser[]
  collections    Collection[]
  assets         Asset[]

  @@map("users")
}

model Workspace {
  id        String   @id @default(uuid())
  name      String
  description String?   
  category    String?   
  thumbnail   String?   
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isPublic  Boolean  @default(false)
  workspaceUsers WorkspaceUser[]
  collections    Collection[]
  assets         Asset[]

  @@map("workspaces")
}

model WorkspaceUser {
  id          String   @id @default(uuid())
  role        Role     @default(MEMBER)
  userId      String
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@unique([userId, workspaceId])
  @@map("workspace_users")
}

model Collection {
  id          String   @id @default(uuid())
  name        String
  userId      String
  workspaceId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@map("collections")
}

model Asset {
  id          String   @id @default(uuid())
  name        String
  type        String   // pdf | url
  url         String?  // for blogs
  filePath    String?  // for S3
  userId      String?
  workspaceId String
  isPublic    Boolean  @default(false) 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User?      @relation(fields: [userId], references: [id])
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@map("assets")
}